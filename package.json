{
  "name": "weixin-claude-bot",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node --import tsx src/index.ts",
    "login": "node --import tsx src/login.ts",
    "config": "node --import tsx src/config.ts",
    "start:1": "WEIXIN_BOT_PROFILE=$HOME/.weixin-bot-1 node --import tsx src/index.ts",
    "login:1": "WEIXIN_BOT_PROFILE=$HOME/.weixin-bot-1 node --import tsx src/login.ts",
    "config:1": "WEIXIN_BOT_PROFILE=$HOME/.weixin-bot-1 node --import tsx src/config.ts",
    "start:2": "WEIXIN_BOT_PROFILE=$HOME/.weixin-bot-2 node --import tsx src/index.ts",
    "login:2": "WEIXIN_BOT_PROFILE=$HOME/.weixin-bot-2 node --import tsx src/login.ts",
    "config:2": "WEIXIN_BOT_PROFILE=$HOME/.weixin-bot-2 node --import tsx src/config.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "qrcode-terminal": "^0.12.0",
    "weixin-ilink": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5"
  }
}
